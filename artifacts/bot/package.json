{
  "name": "@workspace/bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.mjs",
    "build": "node build.mjs",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "clear-commands": "tsx src/clear-commands.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "discord.js": "^14.26.4",
    "drizzle-orm": "catalog:",
    "node-cron": "^3.0.3",
    "winston": "^3.19.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "esbuild": "0.27.3",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
